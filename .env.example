# Dxrk-AI Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control - it's in .gitignore

# ============================================
# OPENAI / AI PROVIDERS (optional)
# ============================================
# For AI provider switching feature
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...
# AZURE_OPENAI_KEY=...
# AZURE_OPENAI_ENDPOINT=https://...

# ============================================
# GITHUB (optional)
# ============================================
# For automatic releases and repository operations
# GITHUB_TOKEN=ghp_...

# ============================================
# HOMEVER (optional)
# ============================================
# For Homebrew tap releases
# HOMEBREW_TOKEN=...

# ============================================
# DEVELOPMENT (optional)
# ============================================
# Debug and development settings
# DXRK_DEBUG=false
# DXRK_LOG_LEVEL=info
# DXRK_TELEMETRY_ENABLED=false

# ============================================
# ENGRAM / DXRK-MEMORY (optional)
# ============================================
# Memory system configuration
# DXRK_MEMORY_SETUP_MODE=auto
# DXRK_MEMORY_SETUP_STRICT=true

# ============================================
# NOTION / JIRA / MCP (optional)
# ============================================
# For MCP server integrations
# NOTION_API_KEY=secret_...
# JIRA_API_TOKEN=...
# JIRA_BASE_URL=https://your-domain.atlassian.net